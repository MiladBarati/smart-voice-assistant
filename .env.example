# Elasticsearch Configuration
# Copy this file to .env and update with your actual values

ES_HOST="localhost"
ES_PORT="9200"
ES_USERNAME="elastic"
ES_PASSWORD=""
ES_USE_SSL="false"
ES_VERIFY_CERTS="false"
ELASTIC_INDEX_PREFIX="pjsua-calls"

# SIP Configuration (required for Docker)
SIP_USER=""
SIP_PASSWORD=""
SIP_DOMAIN=""
SIP_AUTH_USER=""
SIP_TRANSPORT="udp"
SIP_LOCAL_PORT="0"
SIP_WAIT_SECONDS="20"
SIP_MESSAGE_DURATION="8"
SIP_HANGUP_DELAY="2"
SIP_SILENCE_AFTER_SPEECH_SEC="3.0"
SIP_VAD_THRESHOLD="0.5"
