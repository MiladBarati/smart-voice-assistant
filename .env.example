# Elasticsearch Configuration
# Copy this file to .env and update with your actual values

ES_HOST="localhost"
ES_PORT="9200"
ES_USERNAME="elastic"
ES_PASSWORD=""
ES_USE_SSL="false"
ES_VERIFY_CERTS="false"
ELASTIC_INDEX_PREFIX="pjsua-calls"

